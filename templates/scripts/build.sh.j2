#!/usr/bin/env bash
# vim: ft=sh
set -euo pipefail

BRANCH="${1:-{{ beacon_node_repo_branch }}}"
REPO="{{ beacon_node_repo | default('status-im/nimbus-eth2') }}"
SERVICE="{{ beacon_node_service_name }}.service"
SERVICE_PATH="{{ beacon_node_service_path }}"
BIN_PATH="{{ beacon_node_bin_path }}"
TARGETS=({{ beacon_node_update_build_targets | join(" ") }})

echo " >>> Build Start: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
echo " >>> Building branch: ${BRANCH}"

if [[ "${USER}" != "{{ beacon_node_user }}" ]]; then
    echo "Incorrect user: ${USER}" >&2
    echo "Expected: {{ beacon_node_user }}" >&2
    exit 1
fi

# Get latest remote commit
COMMIT=$(curl -sf "https://api.github.com/repos/${REPO}/commits/${BRANCH}" | jq -r '.sha[:8]')
if [[ -z "${COMMIT}" || "${COMMIT}" == "null" ]]; then
    echo " Failed to fetch remote commit!" >&2
    exit 1
fi
echo " >>> Remote commit: ${COMMIT}"

# Check if all binaries already exist
ALL_EXIST=1
for target in "${TARGETS[@]}"; do
    [[ -f "${SERVICE_PATH}/build/${target}_${COMMIT}" ]] || ALL_EXIST=0
done

if [[ ${ALL_EXIST} -eq 1 ]]; then
    echo " >>> Binaries already built for ${COMMIT}"
    exit 0
fi

# Build each target with Nix
echo " >>> Building via nix..."
mkdir -p "${SERVICE_PATH}/build" "${BIN_PATH}"

for target in "${TARGETS[@]}"; do
    echo " >>> Building ${target}..."
    nix build "git+https://github.com/${REPO}?submodules=1&ref=${BRANCH}#${target}" \
        --out-link "${SERVICE_PATH}/build/nix-result-${target}"

    BIN_NAME="nimbus_${target}"
    [[ -f "${SERVICE_PATH}/build/nix-result-${target}/bin/${BIN_NAME}" ]] \
        || BIN_NAME="${target}"

    cp -f "${SERVICE_PATH}/build/nix-result-${target}/bin/${BIN_NAME}" \
          "${SERVICE_PATH}/build/${target}_${COMMIT}"
    ln -vfrs "${SERVICE_PATH}/build/${target}_${COMMIT}" "${BIN_PATH}/${target}"

    rm -f "${SERVICE_PATH}/build/nix-result-${target}"
done

# Cleanup old binaries
find "${SERVICE_PATH}/build" -maxdepth 1 -name '*_*' \
    -mtime +{{ beacon_node_update_build_days_kept }} -delete

{% if beacon_node_update_restarts_service %}
# Avoid faiure on first Ansible run due to missing service.
if [[ $(systemctl is-enabled "${SERVICE}" || true) != "enabled" ]]; then
    echo " !!! No service to restart!"
    exit
else
    echo " >>> Restarting service..."
    sudo systemctl restart "${SERVICE}"
fi
{% endif %}

echo " >>> SUCCESS (${COMMIT})"